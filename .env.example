# CyberPulse AI — Environment Variables
#
# You will set these in the Vercel dashboard (Settings → Environment Variables),
# NOT in this file. This file just documents what's needed.

# From Supabase: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# From Anthropic: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# Optional: a random string to secure the cron endpoints from being called
# by anyone other than Vercel's scheduler. Leave blank to skip this check.
CRON_SECRET=
